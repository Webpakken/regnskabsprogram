# Copy to .env.local — keys from Supabase → Settings → API (anon JWT for browser only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_jwt

# Production (Vercel/Netlify/Cloudflare): add the same VITE_* vars in the host’s Environment Variables.
# Supabase Auth → URL Configuration: Site URL https://bilago.dk + redirect allowlist for bilago.dk
# Edge Functions: APP_URL=https://bilago.dk (Supabase → Edge Function secrets)
